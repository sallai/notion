#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

from __future__ import annotations

import argparse
import json
import os
import re
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any


DEFAULT_NOTION_VERSION = "2026-03-11"
API_BASE = "https://api.notion.com/v1"
NOTION_ENV_FILES = [
    Path.home() / ".notion" / "env",
    Path.home() / ".notion" / "notion.env",
    Path.home() / ".notion" / ".env",
]
AUTH_SETUP_STATUSES = {401, 403}
AUTH_SETUP_CODES = {
    "restricted_resource",
    "unauthorized",
}

RICH_TEXT_CHAR_LIMIT = 2000
BLOCK_CHILDREN_LIMIT = 100

# Inline markdown: bold, italic, code, links (non-greedy, ordered longest-first)
_INLINE_RE = re.compile(
    r"\*\*(.+?)\*\*"
    r"|__(.+?)__"
    r"|\*(.+?)\*"
    r"|_(.+?)_"
    r"|`(.+?)`"
    r"|\[(.+?)\]\(([^)]+)\)",
    re.DOTALL,
)
# Leading emoji: covers Supplemental Multilingual Plane + common BMP symbol blocks
_EMOJI_RE = re.compile(r"^([\U0001F000-\U0001FFFF☀-➿⌀-⏿⭐⭕])\s*(.*)", re.DOTALL)


class NotionError(RuntimeError):
    def __init__(self, status: int, reason: str, message: str, code: str | None = None) -> None:
        self.status = status
        self.reason = reason
        self.code = code
        self.message = message
        detail = f"Notion API {status} {reason}: {message}"
        if code:
            detail = f"{detail} ({code})"
        super().__init__(detail)


class NotionClient:
    def __init__(self, token: str, notion_version: str = DEFAULT_NOTION_VERSION) -> None:
        self.token = token
        self.notion_version = notion_version

    def get(self, path: str) -> dict[str, Any]:
        return self.request("GET", path)

    def post(self, path: str, body: dict[str, Any] | None = None) -> dict[str, Any]:
        return self.request("POST", path, body)

    def patch(self, path: str, body: dict[str, Any] | None = None) -> dict[str, Any]:
        return self.request("PATCH", path, body)

    def delete(self, path: str) -> dict[str, Any]:
        return self.request("DELETE", path)

    def request(self, method: str, path: str, body: dict[str, Any] | None = None) -> dict[str, Any]:
        url = path if path.startswith("http") else f"{API_BASE}{path}"
        payload = None if body is None else json.dumps(body).encode("utf-8")
        request = urllib.request.Request(
            url,
            data=payload,
            method=method,
            headers={
                "Authorization": f"Bearer {self.token}",
                "Notion-Version": self.notion_version,
                "Content-Type": "application/json",
            },
        )

        try:
            with urllib.request.urlopen(request) as response:
                raw = response.read().decode("utf-8")
        except urllib.error.HTTPError as error:
            if error.code == 429:
                retry_after = error.headers.get("Retry-After")
                if retry_after and retry_after.isdigit():
                    time.sleep(int(retry_after))
                    return self.request(method, path, body)

            raw = error.read().decode("utf-8", errors="replace")
            try:
                payload_data = json.loads(raw)
                message = payload_data.get("message", raw)
                code = payload_data.get("code")
            except json.JSONDecodeError:
                message = raw
                code = None
            raise NotionError(error.code, error.reason, message, code) from error

        if not raw:
            return {}
        return json.loads(raw)

    def collect_paginated_get(
        self,
        path: str,
        query: dict[str, str] | None = None,
        limit: int | None = None,
    ) -> list[dict[str, Any]]:
        query = dict(query or {})
        results: list[dict[str, Any]] = []
        cursor = query.get("start_cursor")

        while True:
            page_size = 100 if limit is None else min(100, max(1, limit - len(results)))
            query["page_size"] = str(page_size)
            if cursor:
                query["start_cursor"] = cursor
            else:
                query.pop("start_cursor", None)

            response = self.get(f"{path}?{urllib.parse.urlencode(query)}")
            results.extend(response.get("results", []))
            if limit is not None and len(results) >= limit:
                return results[:limit]
            if not response.get("has_more"):
                return results
            cursor = response.get("next_cursor")

    def collect_paginated_post(
        self,
        path: str,
        body: dict[str, Any] | None = None,
        limit: int | None = None,
    ) -> list[dict[str, Any]]:
        body = dict(body or {})
        results: list[dict[str, Any]] = []
        cursor = body.get("start_cursor")

        while True:
            page_size = 100 if limit is None else min(100, max(1, limit - len(results)))
            body["page_size"] = page_size
            if cursor:
                body["start_cursor"] = cursor
            else:
                body.pop("start_cursor", None)

            response = self.post(path, body)
            results.extend(response.get("results", []))
            if limit is not None and len(results) >= limit:
                return results[:limit]
            if not response.get("has_more"):
                return results
            cursor = response.get("next_cursor")


def main() -> int:
    args = build_parser().parse_args()

    try:
        if not getattr(args, "requires_auth", True):
            return args.func(None, args)

        load_env_files([Path(path).expanduser() for path in args.env_file] if args.env_file else NOTION_ENV_FILES)
        token = os.environ.get("NOTION_TOKEN") or os.environ.get("NOTION_API_KEY") or os.environ.get("NTN_TOKEN")
        if not token:
            print(build_notion_setup_text(), file=sys.stdout, flush=True)
            return 1

        client = NotionClient(token=token, notion_version=args.notion_version)
        return args.func(client, args)
    except (NotionError, RuntimeError, ValueError, OSError, json.JSONDecodeError) as error:
        if isinstance(error, NotionError) and is_auth_setup_error(error):
            print(str(error), file=sys.stderr, flush=True)
            print(build_notion_setup_text(), file=sys.stdout, flush=True)
            return 1
        print(str(error), file=sys.stderr, flush=True)
        return 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="notion-cli",
        description="Single-file Notion API CLI using ~/.notion/env credentials.",
    )
    parser.add_argument(
        "--notion-version",
        default=os.environ.get("NOTION_VERSION", DEFAULT_NOTION_VERSION),
        help=f"Notion-Version header. Default: {DEFAULT_NOTION_VERSION}",
    )
    parser.add_argument(
        "--env-file",
        action="append",
        help="Credential env file to load. Defaults to ~/.notion/env and compatible fallbacks.",
    )

    subparsers = parser.add_subparsers(required=True)

    add_setup_parser(subparsers)
    add_me_parser(subparsers)
    add_api_parser(subparsers)
    add_search_parser(subparsers)
    add_page_parser(subparsers)
    add_block_parser(subparsers)
    add_comment_parser(subparsers)
    add_database_parser(subparsers)
    add_data_source_parser(subparsers)
    add_user_parser(subparsers)

    return parser


def add_setup_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("setup", help="Print Notion integration setup and credential instructions.")
    output = parser.add_mutually_exclusive_group()
    output.add_argument("--env-only", action="store_true", help="Print only the local credential-file instructions.")
    output.add_argument("--capabilities-only", action="store_true", help="Print only the integration capability checklist.")
    output.add_argument("--oauth-note", action="store_true", help="Print a note about public OAuth integrations.")
    parser.set_defaults(func=cmd_setup, requires_auth=False)


def add_me_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("me", help="Show the integration user for the active token.")
    parser.set_defaults(func=cmd_me)


def add_api_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("api", help="Call any Notion API endpoint.")
    parser.add_argument("method", choices=["GET", "POST", "PATCH", "DELETE"])
    parser.add_argument("path", help="API path such as /pages/<id>, or a full https://api.notion.com/v1 URL.")
    parser.add_argument("--data", help="JSON request body, @file.json, or - for stdin.")
    parser.add_argument("--query", action="append", default=[], help="Append query params as key=value.")
    parser.add_argument("--paginate", action="store_true", help="Collect paginated list results.")
    parser.set_defaults(func=cmd_api)


def add_search_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    parser = subparsers.add_parser("search", help="Search shared pages and data sources by title.")
    parser.add_argument("query", nargs="?", default="")
    parser.add_argument("--object", choices=["page", "data_source"])
    parser.add_argument("--limit", type=int, default=25)
    parser.add_argument("--json", action="store_true", help="Print raw JSON results.")
    parser.set_defaults(func=cmd_search)


def add_page_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    page = subparsers.add_parser("page", help="Read, create, update, export, trash, or restore pages.")
    page_sub = page.add_subparsers(required=True)

    get = page_sub.add_parser("get", help="Retrieve a page object.")
    get.add_argument("page")
    get.set_defaults(func=cmd_page_get)

    export = page_sub.add_parser("export", help="Export page content to Markdown and raw JSON.")
    export.add_argument("page")
    export.add_argument("output_base", nargs="?", default="notion-page")
    export.add_argument("--no-json", action="store_true", help="Do not write the raw JSON sidecar file.")
    export.set_defaults(func=cmd_page_export)

    create = page_sub.add_parser("create", help="Create a page.")
    create.add_argument("--body", help="Full JSON body, @file.json, or - for stdin. Overrides convenience flags.")
    create.add_argument("--parent-page", help="Create as child of this page.")
    create.add_argument("--parent-data-source", help="Create as entry in this data source.")
    create.add_argument("--workspace", action="store_true", help="Create a workspace-level private page when supported.")
    create.add_argument("--title", help="Convenience page title.")
    create.add_argument("--title-property", default="title", help="Title property name. Use Name for many data sources.")
    create.add_argument("--properties", help="Additional page properties JSON, @file.json, or - for stdin.")
    create.add_argument("--markdown", help="Convenience block Markdown to add as children.")
    create.add_argument("--markdown-file", help="Read convenience block Markdown from a file.")
    create.set_defaults(func=cmd_page_create)

    update = page_sub.add_parser("update", help="Update page metadata/properties.")
    update.add_argument("page")
    update.add_argument("--body", help="Full PATCH body JSON, @file.json, or - for stdin. Merged after convenience flags.")
    update.add_argument("--title", help="Convenience title update.")
    update.add_argument("--title-property", default="title", help="Title property name. Use Name for many data sources.")
    update.add_argument("--properties", help="Properties JSON, @file.json, or - for stdin.")
    update.add_argument("--icon-emoji", help="Set page icon emoji.")
    update.add_argument("--cover-url", help="Set page cover to an external URL.")
    update.add_argument("--trash", action="store_true", help="Move the page to trash.")
    update.add_argument("--restore", action="store_true", help="Restore the page from trash.")
    update.set_defaults(func=cmd_page_update)

    delete = page_sub.add_parser("delete", help="Trash a page. Notion does not expose permanent page delete.")
    delete.add_argument("page")
    delete.set_defaults(func=cmd_page_delete)

    restore = page_sub.add_parser("restore", help="Restore a page from trash.")
    restore.add_argument("page")
    restore.set_defaults(func=cmd_page_restore)


def add_block_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    block = subparsers.add_parser("block", help="Read, append, update, or delete blocks.")
    block_sub = block.add_subparsers(required=True)

    get = block_sub.add_parser("get", help="Retrieve a block.")
    get.add_argument("block")
    get.set_defaults(func=cmd_block_get)

    children = block_sub.add_parser("children", help="Retrieve block/page children.")
    children.add_argument("block")
    children.add_argument("--recursive", action="store_true")
    children.add_argument("--limit", type=int)
    children.add_argument("--markdown", action="store_true", help="Render children as Markdown.")
    children.set_defaults(func=cmd_block_children)

    append = block_sub.add_parser("append", help="Append children to a block or page.")
    append.add_argument("block")
    append.add_argument("--body", help="Full PATCH body JSON, @file.json, or - for stdin.")
    append.add_argument("--children", help="JSON children array, @file.json, or - for stdin.")
    append.add_argument("--markdown", help="Convenience Markdown to append.")
    append.add_argument("--markdown-file", help="Read convenience Markdown from a file.")
    append.set_defaults(func=cmd_block_append)

    update = block_sub.add_parser("update", help="Update a block.")
    update.add_argument("block")
    update.add_argument("--body", help="Full PATCH body JSON, @file.json, or - for stdin.")
    update.add_argument("--type", choices=["paragraph", "heading_1", "heading_2", "heading_3", "bulleted_list_item", "numbered_list_item", "quote", "to_do", "code"])
    update.add_argument("--text", help="Convenience rich text content for supported block types.")
    update.add_argument("--checked", choices=["true", "false"], help="Set to_do checked state.")
    update.set_defaults(func=cmd_block_update)

    delete = block_sub.add_parser("delete", help="Delete/trash a block.")
    delete.add_argument("block")
    delete.set_defaults(func=cmd_block_delete)


def add_comment_parser(subparsers: argparse._SubParsersAction[argparse.ArgumentParser]) -> None:
    comment = subparsers.add_parser("comment", help="List, create, update, or delete comments.")
    comment_sub = comment.add_subparsers(required=True)

    list_parser = comment_sub.add_parser("list", help="List unresolved comments for a page or block.")
    list_parser.add_argument("block")
    list_parser.add_argument("--limit", type=int, default=100)
    list_parser.set_defaults(func=cmd_comment_list)

    get = comment_sub.add_parser("get", help="Retrieve one comment.")
    get.add_argument("comment")
    get.set_defaults(func=cmd_comment_get)

    create = comment_sub.add_parser("create", help="Create a comment on a page, block, or discussion.")
    parent = create.add_mutually_exclusive_group(required=True)
    parent.add_argument("--page")
    parent.add_argument("--block")
    parent.add_argument("--discussion")
    create.add_argument("--text", help="Plain text comment body.")
    create.add_argument("--markdown", help="Markdown comment body.")
    create.add_argument("--markdown-file", help="Read Markdown comment body from file.")
    create.set_defaults(func=cmd_comment_create)

    update = comment_sub.add_parser("update", help="Update a comment created by this connection.")
    update.add_argument("comment")
    update.add_argument("--text", help="Plain text comment body.")
    update.add_argument("--markdown", help="Markdown comment body.")
    update.add_argument("--markdown-file", help="Read Markdown comment body from file.")
    update.set_defaults(func=cmd_comment_update)

    delete = comment_sub.add_parser("delete", help="Delete a comment created by this connection.")
    delete.add_argument("comment")
    delete.set_defaults(func=cmd_comment_delete)


