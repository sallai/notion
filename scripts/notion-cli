def cmd_setup(_client: NotionClient | None, args: argparse.Namespace) -> int:
    if args.env_only:
        print(build_notion_env_setup_text().rstrip(), flush=True)
    elif args.capabilities_only:
        print(build_notion_capabilities_text().rstrip(), flush=True)
    elif args.oauth_note:
        print(build_notion_oauth_note_text().rstrip(), flush=True)
    else:
        print(build_notion_setup_text().rstrip(), flush=True)
    return 0


def cmd_me(client: NotionClient, _args: argparse.Namespace) -> int:
    emit_json(client.get("/users/me"))
    return 0


def cmd_api(client: NotionClient, args: argparse.Namespace) -> int:
    body = read_json_arg(args.data) if args.data else None

    if args.paginate:
        if args.method == "GET":
            path, query = split_path_query(args.path)
            query.update(query_pairs_to_dict(args.query))
            emit_json(client.collect_paginated_get(path, query))
            return 0
        if args.method == "POST":
            path = add_query_params(args.path, args.query)
            emit_json(client.collect_paginated_post(path, body))
            return 0
        raise ValueError("--paginate is only supported for GET and POST list endpoints.")

    path = add_query_params(args.path, args.query)
    emit_json(client.request(args.method, path, body))
    return 0


def cmd_search(client: NotionClient, args: argparse.Namespace) -> int:
    body: dict[str, Any] = {
        "query": args.query,
        "sort": {"direction": "descending", "timestamp": "last_edited_time"},
    }
    if args.object:
        body["filter"] = {"property": "object", "value": args.object}

    results = client.collect_paginated_post("/search", body, limit=args.limit)
    if args.json:
        emit_json(results)
    else:
        for item in results:
            title = object_title(item)
            print(f"{item.get('object')}\t{item.get('id')}\t{title}\t{item.get('url', '')}", flush=True)
    return 0


def cmd_page_get(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.get(f"/pages/{parse_notion_id(args.page)}"))
    return 0


def cmd_page_export(client: NotionClient, args: argparse.Namespace) -> int:
    page_id = parse_notion_id(args.page)
    page = client.get(f"/pages/{page_id}")
    blocks = list_block_children(client, page_id)
    title = page_title(page)
    markdown = f"# {title}\n\n{blocks_to_markdown(blocks)}\n"

    out_base = Path(args.output_base)
    markdown_path = output_path(out_base, ".md")
    markdown_path.write_text(markdown, encoding="utf-8")
    print(f"Wrote {markdown_path}", flush=True)

    if not args.no_json:
        json_path = output_path(out_base, ".json")
        json_path.write_text(to_json({"page": page, "blocks": blocks}), encoding="utf-8")
        print(f"Wrote {json_path}", flush=True)
    return 0


def cmd_page_create(client: NotionClient, args: argparse.Namespace) -> int:
    body = read_json_arg(args.body) if args.body else build_page_create_body(args)
    children = body.pop("children", [])
    if children:
        body["children"] = children[:BLOCK_CHILDREN_LIMIT]
    page = client.post("/pages", body)
    overflow = children[BLOCK_CHILDREN_LIMIT:]
    if overflow:
        append_blocks_batched(client, page["id"], overflow)
    emit_json(page)
    return 0


def cmd_page_update(client: NotionClient, args: argparse.Namespace) -> int:
    if args.trash and args.restore:
        raise ValueError("Use only one of --trash or --restore.")

    body: dict[str, Any] = {}
    if args.properties:
        body["properties"] = read_json_arg(args.properties)
    if args.title:
        body.setdefault("properties", {})[args.title_property] = title_property(args.title)
    if args.icon_emoji:
        body["icon"] = {"type": "emoji", "emoji": args.icon_emoji}
    if args.cover_url:
        body["cover"] = {"type": "external", "external": {"url": args.cover_url}}
    if args.trash:
        body["in_trash"] = True
    if args.restore:
        body["in_trash"] = False
    if args.body:
        body.update(read_json_arg(args.body))
    if not body:
        raise ValueError("Nothing to update. Provide --body, --title, --properties, --trash, or another update flag.")

    emit_json(client.patch(f"/pages/{parse_notion_id(args.page)}", body))
    return 0


def cmd_page_delete(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.patch(f"/pages/{parse_notion_id(args.page)}", {"in_trash": True}))
    return 0


def cmd_page_restore(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.patch(f"/pages/{parse_notion_id(args.page)}", {"in_trash": False}))
    return 0


def cmd_block_get(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.get(f"/blocks/{parse_notion_id(args.block)}"))
    return 0


def cmd_block_children(client: NotionClient, args: argparse.Namespace) -> int:
    block_id = parse_notion_id(args.block)
    blocks = list_block_children(client, block_id, recursive=args.recursive, limit=args.limit)
    if args.markdown:
        print(blocks_to_markdown(blocks), flush=True)
    else:
        emit_json(blocks)
    return 0


def cmd_block_append(client: NotionClient, args: argparse.Namespace) -> int:
    block_id = parse_notion_id(args.block)
    if args.body:
        body = read_json_arg(args.body)
        children = body.get("children")
        if children is None:
            emit_json(client.patch(f"/blocks/{block_id}/children", body))
        else:
            emit_json(append_blocks_batched(client, block_id, children))
    else:
        emit_json(append_blocks_batched(client, block_id, build_children_from_args(args)))
    return 0


def cmd_block_update(client: NotionClient, args: argparse.Namespace) -> int:
    if args.body:
        body = read_json_arg(args.body)
    else:
        if not args.type:
            raise ValueError("Provide --body or --type for block update.")
        if args.text is None and args.checked is None:
            raise ValueError("Provide --text or --checked with --type.")
        body = build_block_update_body(args.type, args.text, args.checked)

    emit_json(client.patch(f"/blocks/{parse_notion_id(args.block)}", body))
    return 0


def cmd_block_delete(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.delete(f"/blocks/{parse_notion_id(args.block)}"))
    return 0


def cmd_comment_list(client: NotionClient, args: argparse.Namespace) -> int:
    results = client.collect_paginated_get(
        "/comments",
        {"block_id": parse_notion_id(args.block)},
        limit=args.limit,
    )
    emit_json(results)
    return 0


def cmd_comment_get(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.get(f"/comments/{parse_notion_id(args.comment)}"))
    return 0


def cmd_comment_create(client: NotionClient, args: argparse.Namespace) -> int:
    body = comment_body(args)
    if args.page:
        body["parent"] = {"page_id": parse_notion_id(args.page)}
    elif args.block:
        body["parent"] = {"block_id": parse_notion_id(args.block)}
    elif args.discussion:
        body["discussion_id"] = parse_notion_id(args.discussion)
    emit_json(client.post("/comments", body))
    return 0


def cmd_comment_update(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.patch(f"/comments/{parse_notion_id(args.comment)}", comment_body(args)))
    return 0


def cmd_comment_delete(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.delete(f"/comments/{parse_notion_id(args.comment)}"))
    return 0


def cmd_database_get(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.get(f"/databases/{parse_notion_id(args.database)}"))
    return 0


def cmd_database_create(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.post("/databases", read_json_arg(args.body)))
    return 0


def cmd_database_update(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.patch(f"/databases/{parse_notion_id(args.database)}", read_json_arg(args.body)))
    return 0


def cmd_data_source_get(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.get(f"/data_sources/{parse_notion_id(args.data_source)}"))
    return 0


def cmd_data_source_query(client: NotionClient, args: argparse.Namespace) -> int:
    body = read_json_arg(args.body) if args.body else {}
    if args.limit:
        emit_json(client.collect_paginated_post(f"/data_sources/{parse_notion_id(args.data_source)}/query", body, args.limit))
    else:
        emit_json(client.post(f"/data_sources/{parse_notion_id(args.data_source)}/query", body))
    return 0


def cmd_data_source_create(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.post("/data_sources", read_json_arg(args.body)))
    return 0


def cmd_data_source_update(client: NotionClient, args: argparse.Namespace) -> int:
