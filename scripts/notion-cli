def cmd_user_list(client: NotionClient, args: argparse.Namespace) -> int:
    emit_json(client.collect_paginated_get("/users", limit=args.limit))
    return 0


def load_env_files(paths: list[Path]) -> None:
    for path in paths:
        if path.exists():
            load_env_file(path)


def load_env_file(path: Path) -> None:
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :].strip()

        key, separator, value = line.partition("=")
        if not separator:
            continue
        key = key.strip()
        if key and key not in os.environ:
            os.environ[key] = strip_env_quotes(value.strip())


def strip_env_quotes(value: str) -> str:
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    return value


def build_notion_setup_text() -> str:
    return f"""Notion access is not set up for notion-cli.

This CLI uses the official Notion API with an internal integration token stored
outside the repository. Notion still requires each target page, database, or
wiki area to be shared with the integration before the API can read or edit it.

1. Create the internal integration:

- Open https://www.notion.so/my-integrations.
- Create a new internal integration in the correct workspace.
- Give it a clear name such as "Local Notion CLI".
- Copy the internal integration secret. The token should start with ntn_.

2. Enable the capabilities this CLI needs:

{build_notion_capabilities_text().rstrip()}

3. Share content with the integration:

- Open the target page or database in Notion.
- Use Share, Connections, or Add connections.
- Add the internal integration to that page or database.
- Repeat this for each page, database, or parent area the CLI must access.
- If the API returns restricted_resource or HTTP 403, the token is usually valid
  but the integration was not shared with the target content or lacks a needed
  capability.

{build_notion_env_setup_text().rstrip()}

{build_notion_oauth_note_text().rstrip()}

Reference docs:
- Authorization: https://developers.notion.com/docs/authorization
- Create an integration: https://developers.notion.com/docs/create-a-notion-integration
- Authentication: https://developers.notion.com/reference/authentication
- Capabilities: https://developers.notion.com/reference/capabilities
"""


def build_notion_capabilities_text() -> str:
    return """For broad CLI use, enable these Notion integration capabilities:

- Read content: required for search, page export, block reads, and data-source queries.
- Insert content: required for creating pages, appending blocks, and creating comments.
- Update content: required for page updates, block updates, trash/restore, and schema updates.
- Read comments: required for listing or reading comments.
- Insert comments: required for creating or updating comments.
- Read user information: required for user list/user lookup commands.

Use a smaller capability set only if the intended CLI use is intentionally read-only or otherwise constrained."""


def build_notion_env_setup_text() -> str:
    return """4. Store the token outside this repository:

```sh
mkdir -p ~/.notion
chmod 700 ~/.notion
$EDITOR ~/.notion/env
chmod 600 ~/.notion/env
```

Put this in ~/.notion/env:

```sh
NOTION_TOKEN=ntn_your_token_here
```

Then verify access:

```sh
uv run scripts/notion-cli me
```
"""


def build_notion_oauth_note_text() -> str:
    return """OAuth note:

Use a public OAuth integration only when this CLI is being adapted into an app
that needs to install into other users' workspaces. This local CLI does not
implement an OAuth callback or token exchange flow. For local agent work, use
an internal integration token in ~/.notion/env."""


def is_auth_setup_error(error: NotionError) -> bool:
    return error.status in AUTH_SETUP_STATUSES or (error.code or "") in AUTH_SETUP_CODES


def read_json_arg(value: str) -> Any:
    if value == "-":
        return json.loads(sys.stdin.read())
    if value.startswith("@"):
        return json.loads(Path(value[1:]).expanduser().read_text(encoding="utf-8"))
    return json.loads(value)


def add_query_params(path: str, pairs: list[str]) -> str:
    if not pairs:
        return path

    parsed = list(query_pairs_to_dict(pairs).items())
    separator = "&" if "?" in path else "?"
    return f"{path}{separator}{urllib.parse.urlencode(parsed)}"


def query_pairs_to_dict(pairs: list[str]) -> dict[str, str]:
    parsed: dict[str, str] = {}
    for pair in pairs:
        key, separator, value = pair.partition("=")
        if not separator:
            raise ValueError(f"Invalid --query value {pair!r}; expected key=value.")
        parsed[key] = value
    return parsed


def split_path_query(path: str) -> tuple[str, dict[str, str]]:
    base, separator, query = path.partition("?")
    if not separator:
        return path, {}
    return base, dict(urllib.parse.parse_qsl(query, keep_blank_values=True))


def emit_json(value: Any) -> None:
    print(to_json(value), flush=True)


def to_json(value: Any) -> str:
    return json.dumps(value, indent=2, ensure_ascii=False)


def parse_notion_id(value: str) -> str:
    compact = re.search(r"[0-9a-fA-F]{32}", value)
    if compact:
        raw = compact.group(0)
        return f"{raw[0:8]}-{raw[8:12]}-{raw[12:16]}-{raw[16:20]}-{raw[20:32]}"

    dashed = re.search(
        r"[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}",
        value,
    )
    if dashed:
        return dashed.group(0)

    raise ValueError(f"Could not find a Notion UUID in: {value}")


def output_path(base: Path, suffix: str) -> Path:
    return base.parent / f"{base.name}{suffix}"


def text_object(content: str) -> dict[str, Any]:
    return {"type": "text", "text": {"content": content}}


def rich_text_array(content: str) -> list[dict[str, Any]]:
    if not content:
        return []
    return [text_object(content[i : i + RICH_TEXT_CHAR_LIMIT]) for i in range(0, len(content), RICH_TEXT_CHAR_LIMIT)]


def title_property(title: str) -> dict[str, Any]:
    return {"title": rich_text_array(title)}


def build_page_create_body(args: argparse.Namespace) -> dict[str, Any]:
    body: dict[str, Any] = {}
    if args.parent_page:
        body["parent"] = {"page_id": parse_notion_id(args.parent_page)}
    elif args.parent_data_source:
        body["parent"] = {"data_source_id": parse_notion_id(args.parent_data_source)}
    elif args.workspace:
        body["parent"] = {"workspace": True}
    else:
        raise ValueError("Provide --parent-page, --parent-data-source, --workspace, or --body.")

    properties = read_json_arg(args.properties) if args.properties else {}
    if args.title:
        properties[args.title_property] = title_property(args.title)
    if properties:
        body["properties"] = properties

    children = build_children_from_args(args, required=False)
    if children:
        body["children"] = children

    return body


def build_children_from_args(args: argparse.Namespace, required: bool = True) -> list[dict[str, Any]]:
    if getattr(args, "children", None):
        children = read_json_arg(args.children)
        if not isinstance(children, list):
            raise ValueError("--children must decode to a JSON array.")
        return children

    markdown = None
    if getattr(args, "markdown", None) is not None:
        markdown = args.markdown
    elif getattr(args, "markdown_file", None):
        markdown = Path(args.markdown_file).expanduser().read_text(encoding="utf-8")

    if markdown is not None:
        return markdown_to_blocks(markdown)
    if required:
        raise ValueError("Provide --body, --children, --markdown, or --markdown-file.")
    return []


def build_block_update_body(block_type: str, text: str | None, checked: str | None) -> dict[str, Any]:
    block: dict[str, Any] = {}
    if text is not None:
        if block_type == "code":
            block["rich_text"] = rich_text_array(text)
            block.setdefault("language", "plain text")
        else:
            block["rich_text"] = rich_text_array(text)
    if checked is not None:
        if block_type != "to_do":
            raise ValueError("--checked can only be used with --type to_do.")
        block["checked"] = checked == "true"
    return {block_type: block}


def comment_body(args: argparse.Namespace) -> dict[str, Any]:
    values = [args.text is not None, args.markdown is not None, args.markdown_file is not None]
    if sum(values) != 1:
        raise ValueError("Provide exactly one of --text, --markdown, or --markdown-file.")
    if args.text is not None:
        return {"rich_text": rich_text_array(args.text)}
    if args.markdown_file:
        return {"markdown": Path(args.markdown_file).expanduser().read_text(encoding="utf-8")}
    return {"markdown": args.markdown}


def append_blocks_batched(client: NotionClient, block_id: str, children: list[dict[str, Any]]) -> dict[str, Any]:
    """Append children in batches of BLOCK_CHILDREN_LIMIT to respect the Notion API limit."""
    if not children:
        return {"object": "list", "results": [], "type": "block", "block": {}}
    all_results: list[dict[str, Any]] = []
    for i in range(0, len(children), BLOCK_CHILDREN_LIMIT):
        response = client.patch(f"/blocks/{block_id}/children", {"children": children[i : i + BLOCK_CHILDREN_LIMIT]})
        all_results.extend(response.get("results", []))
    return {"object": "list", "results": all_results, "type": "block", "block": {}}


def list_block_children(
    client: NotionClient,
    block_id: str,
    recursive: bool = True,
    limit: int | None = None,
) -> list[dict[str, Any]]:
    results = client.collect_paginated_get(f"/blocks/{block_id}/children", limit=limit)
    if recursive:
        for block in results:
            if block.get("has_children"):
                block["children"] = list_block_children(client, block["id"], recursive=True)
    return results


def markdown_to_blocks(markdown: str) -> list[dict[str, Any]]:
    blocks: list[dict[str, Any]] = []
    code_lines: list[str] | None = None
    code_language = "plain text"
    table_lines: list[str] = []

    def flush_table() -> None:
        if table_lines:
            blocks.append(build_table_block(list(table_lines)))
            table_lines.clear()

    for raw_line in markdown.splitlines():
        line = raw_line.rstrip()

        if code_lines is not None:
            if line.startswith("```"):
                blocks.append(code_block("\n".join(code_lines), code_language))
                code_lines = None
                code_language = "plain text"
            else:
                code_lines.append(line)
            continue

        if line.startswith("```"):
            flush_table()
            code_language = line[3:].strip() or "plain text"
            code_lines = []
            continue

        if line.startswith("|"):
            table_lines.append(line)
            continue

        flush_table()

        if not line.strip():
            continue
        if line == "---":
            blocks.append({"object": "block", "type": "divider", "divider": {}})
            continue

        heading_match = re.match(r"^(#{1,3})\s+(.+)$", line)
        if heading_match:
            level = len(heading_match.group(1))
            block_type = f"heading_{level}"
            blocks.append(rich_text_block(block_type, heading_match.group(2)))
            continue

        todo_match = re.match(r"^- \[([ xX])\]\s+(.+)$", line)
        if todo_match:
            blocks.append(
                {
                    "object": "block",
                    "type": "to_do",
                    "to_do": {
                        "rich_text": parse_inline_markdown(todo_match.group(2)),
                        "checked": todo_match.group(1).lower() == "x",
                    },
                }
            )
            continue

        bullet_match = re.match(r"^[-*]\s+(.+)$", line)
        if bullet_match:
            blocks.append(rich_text_block("bulleted_list_item", bullet_match.group(1)))
            continue

        number_match = re.match(r"^\d+[.)]\s+(.+)$", line)
        if number_match:
            blocks.append(rich_text_block("numbered_list_item", number_match.group(1)))
            continue

        quote_match = re.match(r"^>\s+(.+)$", line)
        if quote_match:
            content = quote_match.group(1)
            emoji_match = _EMOJI_RE.match(content)
            if emoji_match:
                blocks.append({
                    "object": "block",
                    "type": "callout",
                    "callout": {
                        "rich_text": parse_inline_markdown(emoji_match.group(2)),
                        "icon": {"type": "emoji", "emoji": emoji_match.group(1)},
                    },
                })
            else:
                blocks.append(rich_text_block("quote", content))
            continue

        blocks.append(rich_text_block("paragraph", line))

    flush_table()
    if code_lines is not None:
        blocks.append(code_block("\n".join(code_lines), code_language))

    return blocks


def parse_inline_markdown(text: str) -> list[dict[str, Any]]:
    """Convert inline markdown (bold, italic, code, links) to Notion rich_text objects."""
    parts: list[dict[str, Any]] = []
    last = 0
    for m in _INLINE_RE.finditer(text):
        if m.start() > last:
            parts.extend(rich_text_array(text[last : m.start()]))
        bold1, bold2, ital1, ital2, code, link_text, link_url = m.groups()
        if bold1 or bold2:
            raw = bold1 or bold2
            for chunk in (raw[i : i + RICH_TEXT_CHAR_LIMIT] for i in range(0, max(1, len(raw)), RICH_TEXT_CHAR_LIMIT)):
                parts.append({"type": "text", "text": {"content": chunk}, "annotations": {"bold": True}})
        elif ital1 or ital2:
            raw = ital1 or ital2
            for chunk in (raw[i : i + RICH_TEXT_CHAR_LIMIT] for i in range(0, max(1, len(raw)), RICH_TEXT_CHAR_LIMIT)):
                parts.append({"type": "text", "text": {"content": chunk}, "annotations": {"italic": True}})
        elif code:
            for chunk in (code[i : i + RICH_TEXT_CHAR_LIMIT] for i in range(0, max(1, len(code)), RICH_TEXT_CHAR_LIMIT)):
                parts.append({"type": "text", "text": {"content": chunk}, "annotations": {"code": True}})
        elif link_text is not None:
            parts.append({"type": "text", "text": {"content": link_text, "link": {"url": link_url}}})
        last = m.end()
    if last < len(text):
        parts.extend(rich_text_array(text[last:]))
    return parts or rich_text_array(text)


def build_table_block(lines: list[str]) -> dict[str, Any]:
    """Convert GFM pipe-table lines into a Notion table block with nested table_row children."""
    rows: list[list[str]] = []
    has_header = False
    for line in lines:
        if re.match(r"^\|[\s\-|:]+\|$", line):
            has_header = True
            continue
        cells = [c.strip() for c in line.strip("|").split("|")]
        rows.append(cells)
    width = max((len(r) for r in rows), default=0)
    return {
        "object": "block",
        "type": "table",
        "table": {"table_width": width, "has_column_header": has_header, "has_row_header": False},
        "children": [
            {
                "object": "block",
                "type": "table_row",
                "table_row": {"cells": [parse_inline_markdown(c) for c in row]},
            }
            for row in rows
        ],
    }


def rich_text_block(block_type: str, content: str) -> dict[str, Any]:
    return {"object": "block", "type": block_type, block_type: {"rich_text": parse_inline_markdown(content)}}


def code_block(content: str, language: str) -> dict[str, Any]:
    return {
        "object": "block",
        "type": "code",
        "code": {"rich_text": rich_text_array(content), "language": language},
    }


def rich_text(items: list[dict[str, Any]] | None) -> str:
    parts = []
    for item in items or []:
        if not isinstance(item, dict):
            continue
        text_data = item.get("text") or {}
        link_data = text_data.get("link") or {}
        text = item.get("plain_text", "")
        href = item.get("href") or link_data.get("url")

        if item.get("type") == "mention" and not text:
            mention = item.get("mention") or {}
            text = (mention.get("page") or {}).get("id") or (mention.get("database") or {}).get("id") or ""

        annotations = item.get("annotations", {})
        if annotations.get("code"):
            text = f"`{text}`"
        if annotations.get("bold"):
            text = f"**{text}**"
        if annotations.get("italic"):
            text = f"_{text}_"
        if annotations.get("strikethrough"):
            text = f"~~{text}~~"
        if href:
            text = f"[{text}]({href})"

        parts.append(text)
    return "".join(parts)


def page_title(page: dict[str, Any]) -> str:
    for prop in page.get("properties", {}).values():
        if prop.get("type") == "title":
            title = rich_text(prop.get("title"))
            if title:
                return title
    return page.get("id", "Untitled")


def object_title(obj: dict[str, Any]) -> str:
    if obj.get("object") == "page":
        return page_title(obj)
    title = rich_text(obj.get("title"))
    if title:
        return title
    return obj.get("name") or obj.get("id", "")


def indent_lines(text: str, prefix: str) -> str:
    return "\n".join(f"{prefix}{line}" if line else line for line in text.splitlines())


def render_children(block: dict[str, Any], depth: int) -> str:
    children = block.get("children") or []
    if not children:
        return ""
    return "\n" + blocks_to_markdown(children, depth + 1)


def file_url(data: dict[str, Any]) -> str:
    return data.get("external", {}).get("url") or data.get("file", {}).get("url") or ""


def block_to_markdown(block: dict[str, Any], depth: int = 0, index: int = 1) -> str:
    block_type = block.get("type")
    data = block.get(block_type, {}) if block_type else {}
    children = render_children(block, depth)
    pad = "  " * depth

    if block_type == "paragraph":
        text = rich_text(data.get("rich_text"))
        return f"{pad}{text}{children}" if text else children.rstrip()
    if block_type == "heading_1":
        return f"# {rich_text(data.get('rich_text'))}{children}"
    if block_type == "heading_2":
        return f"## {rich_text(data.get('rich_text'))}{children}"
    if block_type == "heading_3":
        return f"### {rich_text(data.get('rich_text'))}{children}"
    if block_type == "heading_4":
        return f"#### {rich_text(data.get('rich_text'))}{children}"
    if block_type == "bulleted_list_item":
        nested = f"\n{indent_lines(children.rstrip(), '  ')}" if children else ""
        return f"{pad}- {rich_text(data.get('rich_text'))}{nested}"
    if block_type == "numbered_list_item":
        nested = f"\n{indent_lines(children.rstrip(), '   ')}" if children else ""
        return f"{pad}{index}. {rich_text(data.get('rich_text'))}{nested}"
    if block_type == "to_do":
        checked = "x" if data.get("checked") else " "
        return f"{pad}- [{checked}] {rich_text(data.get('rich_text'))}{children}"
    if block_type == "toggle":
        return f"{pad}<details><summary>{rich_text(data.get('rich_text'))}</summary>\n{children.strip()}\n</details>"
    if block_type == "quote":
        nested = f"\n{indent_lines(children.rstrip(), '> ')}" if children else ""
        return f"{pad}> {rich_text(data.get('rich_text'))}{nested}"
    if block_type == "callout":
        icon = f"{data.get('icon', {}).get('emoji')} " if data.get("icon", {}).get("emoji") else ""
        nested = f"\n{indent_lines(children.rstrip(), '> ')}" if children else ""
        return f"{pad}> {icon}{rich_text(data.get('rich_text'))}{nested}"
    if block_type == "code":
        language = data.get("language", "")
        return f"{pad}```{language}\n{rich_text(data.get('rich_text'))}\n{pad}```"
    if block_type == "equation":
        return f"{pad}$${data.get('expression', '')}$$"
    if block_type == "divider":
        return f"{pad}---"
    if block_type == "image":
        caption = rich_text(data.get("caption")) or "image"
        return f"{pad}![{caption}]({file_url(data)})"
    if block_type in ("file", "pdf", "video", "audio"):
        caption = rich_text(data.get("caption")) or data.get("name") or block_type
        return f"{pad}[{caption}]({file_url(data)})"
    if block_type in ("bookmark", "embed", "link_preview"):
        return f"{pad}{data.get('url', '')}"
    if block_type == "child_page":
        return f"{pad}- {data.get('title', 'Untitled child page')}{children}"
    if block_type == "child_database":
        return f"{pad}- Database: {data.get('title') or block.get('id')}"
    if block_type in ("table", "column_list", "column", "synced_block"):
        return children.rstrip()
    if block_type == "table_row":
        cells = " | ".join(rich_text(cell) for cell in data.get("cells", []))
        return f"{pad}| {cells} |"
    if block_type == "unsupported":
        return f"{pad}> Unsupported Notion block: {block.get('id')}"

    text = rich_text(data.get("rich_text"))
    return f"{pad}{text or f'Unsupported block type: {block_type}'}{children}"


def blocks_to_markdown(blocks: list[dict[str, Any]], depth: int = 0) -> str:
    rendered = []
    numbered_index = 1

    for block in blocks:
        if block.get("type") == "numbered_list_item":
            rendered.append(block_to_markdown(block, depth, numbered_index))
            numbered_index += 1
        else:
            numbered_index = 1
            rendered.append(block_to_markdown(block, depth))

    return "\n\n".join(item for item in rendered if item)


if __name__ == "__main__":
    raise SystemExit(main())
